CATMAP_DATABASE_HOST=203.0.113.10
CATMAP_DATABASE_PORT=35432
CATMAP_DATABASE_NAME=catmap
CATMAP_DATABASE_USER=catmap_app
CATMAP_DATABASE_PASSWORD=change-me
CATMAP_DATABASE_URL=postgresql+psycopg://catmap_app:change-me@203.0.113.10:35432/catmap

CATMAP_JWT_SECRET_KEY=replace-with-at-least-32-random-bytes
CATMAP_JWT_ALGORITHM=HS256
CATMAP_ACCESS_TOKEN_EXPIRE_SECONDS=604800
CATMAP_CAPTCHA_SECRET_KEY=replace-with-another-32-byte-secret
CATMAP_CAPTCHA_EXPIRE_SECONDS=300
CATMAP_AUTH_LOCK_FAILED_ATTEMPTS=5
CATMAP_AUTH_LOCK_MINUTES=15
CATMAP_AMAP_WEB_KEY=replace-with-amap-web-key
CATMAP_AMAP_SECURITY_JS_CODE=replace-with-amap-security-js-code
CATMAP_TENCENT_COS_SECRET_ID=replace-with-cos-secret-id
CATMAP_TENCENT_COS_SECRET_KEY=replace-with-cos-secret-key
CATMAP_TENCENT_COS_REGION=ap-guangzhou
CATMAP_TENCENT_COS_BUCKET=replace-with-cos-bucket
CATMAP_TENCENT_COS_APP_ID=replace-with-cos-app-id
CATMAP_TENCENT_COS_SCHEME=https
CATMAP_TENCENT_COS_DOMAIN=https://replace-with-cos-bucket.cos.ap-guangzhou.myqcloud.com
CATMAP_TENCENT_COS_CDN_DOMAIN=
CATMAP_TENCENT_COS_ENV_PREFIX=dev
CATMAP_FILE_UPLOAD_MAX_MB=10
CATMAP_FILE_IMAGE_MAX_PIXELS=50000000
# Local development: allow loopback origins on any port.
# Deployment: clear this regex, set exact origins if needed, and prefer nginx same-origin proxying.
CATMAP_CORS_ALLOW_ORIGINS=
CATMAP_CORS_ALLOW_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1|\[::1\])(:[0-9]+)?$
