var config = {
  rpxRatio: 0.5
};

function px(rpx) {
  return rpx * config.rpxRatio;
}

function getOpenFromState(value) {
  return !!(value && value.open);
}

function updateConfig(value) {
  if (value && value.rpxRatio) {
    config.rpxRatio = value.rpxRatio;
  }
}

var MENU_TRANSITION = 'opacity 0.18s ease, transform 0.18s ease';
var ARROW_TRANSITION = 'transform 0.18s ease';

function apply(open, ownerInstance) {
  var chipWidth = open ? 336 : 224;
  var hitWidth = open ? 360 : 244;
  var menuOpacity = open ? 1 : 0;
  var menuTransform = open ? 'translateY(0px)' : 'translateY(' + px(-8) + 'px)';
  var arrowTransform = open ? 'rotate(0deg)' : 'rotate(180deg)';

  var hitLayer = ownerInstance.selectComponent('.filter-panel-hit-layer');
  if (hitLayer) {
    hitLayer.setStyle({
      width: px(hitWidth) + 'px'
    });
  }

  var chip = ownerInstance.selectComponent('.filter-chip');
  if (chip) {
    chip.setStyle({
      width: px(chipWidth) + 'px'
    });
  }

  var menu = ownerInstance.selectComponent('.filter-menu');
  if (menu) {
    menu.setStyle({
      opacity: menuOpacity,
      transform: menuTransform,
      transition: MENU_TRANSITION
    });
  }

  var arrow = ownerInstance.selectComponent('.filter-arrow-icon');
  if (arrow) {
    arrow.setStyle({
      transform: arrowTransform,
      transition: ARROW_TRANSITION
    });
  }
}

function sync(newValue, oldValue, ownerInstance, instance) {
  updateConfig(newValue);
  apply(getOpenFromState(newValue), ownerInstance);
}

module.exports = {
  sync: sync
};
